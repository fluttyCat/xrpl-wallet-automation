# XRPL Testnet account to monitor
XRPL_ACCOUNT=your_sender_testnet_address

# XRPL Testnet JSON-RPC endpoint
XRPL_RPC_URL=https://s.altnet.rippletest.net:51234/

# Sender secret for Testnet payment flow only.
# Do not commit or share your real .env file.
XRPL_SECRET=your_sender_testnet_secret

# Receiver Testnet wallet address
XRPL_RECEIVER=your_receiver_testnet_address

# Optional. If empty, the script creates a local fallback summary.
OPENAI_API_KEY=

# Optional OpenAI model
OPENAI_MODEL=gpt-4.1-mini

# Number of transactions to fetch
XRPL_LIMIT=50
